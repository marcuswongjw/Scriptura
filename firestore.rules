rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function currentRole() {
      return ('role' in resource.data) ? resource.data.role : 'user';
    }

    function roleUnchanged() {
      return request.resource.data.role == currentRole();
    }

    match /users/{userId} {
      allow read: if isSignedIn();

      allow create: if isOwner(userId)
        && request.resource.data.role == 'user';

      // Own profile: never change role (prevents accidental self-demotion via saveState).
      // Admins may update OTHER users (including role promote/demote).
      allow update: if (isOwner(userId) && roleUnchanged())
        || (isAdmin() && request.auth.uid != userId);

      allow delete: if isAdmin();
    }

    match /messages/{msgId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.senderUid == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 2000;
      allow update, delete: if isSignedIn()
        && (resource.data.senderUid == request.auth.uid || isAdmin());
    }

    function onlyAttendeeFieldsChanged() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['attendees']);
    }

    function attendeesList(data) {
      return ('attendees' in data) ? data.attendees : [];
    }

    // Self-only RSVP: list size changes by 1 and the only delta involves auth.uid
    function isSelfRsvpJoin() {
      let before = attendeesList(resource.data);
      let after = attendeesList(request.resource.data);
      return after.size() == before.size() + 1
        && request.auth.uid in after
        && !(request.auth.uid in before)
        && after.size() <= 100;
    }

    function isSelfRsvpLeave() {
      let before = attendeesList(resource.data);
      let after = attendeesList(request.resource.data);
      return after.size() == before.size() - 1
        && request.auth.uid in before
        && !(request.auth.uid in after);
    }

    match /events/{eventId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn() && (
        (eventId == 'module_schedules' && isAdmin())
        || (eventId != 'module_schedules'
            && request.resource.data.hostUid == request.auth.uid
            && request.resource.data.title is string
            && request.resource.data.title.size() > 0
            && request.resource.data.title.size() <= 200)
      );

      allow update: if isSignedIn() && (
        (eventId == 'module_schedules' && isAdmin())
        || (eventId != 'module_schedules' && (
          resource.data.hostUid == request.auth.uid
          || isAdmin()
          || (onlyAttendeeFieldsChanged() && (isSelfRsvpJoin() || isSelfRsvpLeave()))
        ))
      );

      allow delete: if isSignedIn() && (
        (eventId == 'module_schedules' && isAdmin())
        || (eventId != 'module_schedules'
            && (resource.data.hostUid == request.auth.uid || isAdmin()))
      );
    }

    match /custom_modules/{modId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /custom_modules_backups/{backupId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /stats/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Reflections: public readable to all signed-in; private only to author/admin
    match /daily_reflections/{dateId}/entries/{userId} {
      allow read: if isSignedIn() && (
        !('isPublic' in resource.data) || resource.data.isPublic == true
        || resource.data.authorUid == request.auth.uid
        || isAdmin()
      );

      allow create: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 1200
        && request.resource.data.dateKey == dateId
        && request.resource.data.isPublic is bool;

      allow update: if isSignedIn() && (
        // Owner full content update
        (
          request.auth.uid == userId
          && resource.data.authorUid == request.auth.uid
          && request.resource.data.authorUid == resource.data.authorUid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 1200
        )
        // Anyone can soft-report (flag only)
        || (
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['reported', 'reportedBy', 'reportedAt'])
          && request.resource.data.reported == true
        )
        // Admin can clear reports / moderate
        || isAdmin()
      );

      allow delete: if isSignedIn()
        && (request.auth.uid == userId || isAdmin());
    }

    match /daily_reflections/{dateId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // In-app notification fanout
    match /notifications/{notifId} {
      allow read: if isSignedIn()
        && resource.data.recipientUid == request.auth.uid;

      allow create: if isSignedIn()
        && request.resource.data.recipientUid is string
        && request.resource.data.recipientUid != request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.title.size() <= 120
        && request.resource.data.body is string
        && request.resource.data.body.size() <= 400;

      allow update: if isSignedIn()
        && resource.data.recipientUid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);

      allow delete: if isSignedIn()
        && (resource.data.recipientUid == request.auth.uid || isAdmin());
    }
  }
}
