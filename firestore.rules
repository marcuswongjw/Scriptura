rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Role stored on users/{uid}. Bootstrap first admin via Firebase Console.
    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Treat missing role as 'user' so legacy docs can still update progress.
    function currentRole() {
      return ('role' in resource.data) ? resource.data.role : 'user';
    }

    function roleUnchanged() {
      return request.resource.data.role == currentRole();
    }

    // Users: anyone signed in can read (network/admin lists).
    // Create: owner only, role forced to 'user'.
    // Update: owner may update own fields but cannot change role;
    //         admins may update any user (including role promote/demote).
    match /users/{userId} {
      allow read: if isSignedIn();

      allow create: if isOwner(userId)
        && request.resource.data.role == 'user';

      allow update: if (isOwner(userId) && roleUnchanged())
        || isAdmin();

      allow delete: if isAdmin();
    }

    // Chat: auth read; create only as self; edit/delete own or admin.
    match /messages/{msgId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.senderUid == request.auth.uid;
      allow update, delete: if isSignedIn()
        && (resource.data.senderUid == request.auth.uid || isAdmin());
    }

    // Events + special doc events/module_schedules (admin-only writes).
    match /events/{eventId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn() && (
        (eventId == 'module_schedules' && isAdmin())
        || (eventId != 'module_schedules'
            && request.resource.data.hostUid == request.auth.uid)
      );

      allow update, delete: if isSignedIn() && (
        (eventId == 'module_schedules' && isAdmin())
        || (eventId != 'module_schedules'
            && (resource.data.hostUid == request.auth.uid || isAdmin()))
      );
    }

    // Curriculum / publisher content: admin write only.
    match /custom_modules/{modId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /custom_modules_backups/{backupId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Aggregated dashboard stats: auth read, admin write.
    match /stats/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Daily reading reflections: one entry per user per local calendar day.
    // Aggregated for the community under daily_reflections/{YYYY-MM-DD}/entries/{uid}
    match /daily_reflections/{dateId}/entries/{userId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 1200
        && request.resource.data.dateKey == dateId;

      allow update: if isSignedIn()
        && request.auth.uid == userId
        && resource.data.authorUid == request.auth.uid
        && request.resource.data.authorUid == resource.data.authorUid
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 1200;

      allow delete: if isSignedIn()
        && (request.auth.uid == userId || isAdmin());
    }

    // Parent date docs (unused, but deny client writes if created).
    match /daily_reflections/{dateId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}
